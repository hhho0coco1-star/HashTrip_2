<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="notice_mapper">

    <select id="selectAll" resultType="com.app.dto.NoticeDTO">
        SELECT * FROM notice ORDER BY notice_no DESC
    </select>

    <select id="selectByNo" resultType="com.app.dto.NoticeDTO">
        SELECT * FROM notice WHERE notice_no = #{noticeNo}
    </select>

    <update id="increaseViewCount">
        UPDATE notice
        SET view_count = NVL(view_count, 0) + 1
        WHERE notice_no = #{noticeNo}
    </update>

    <insert id="insert">
        INSERT INTO notice (title, content)
        VALUES (#{title}, #{content})
    </insert>

    <update id="update">
        UPDATE notice 
        SET title=#{title}, content=#{content}, updated_at=SYSDATE
        WHERE notice_no=#{noticeNo}
    </update>

    <delete id="delete">
        DELETE FROM notice WHERE notice_no=#{noticeNo}
    </delete>
    
</mapper>
